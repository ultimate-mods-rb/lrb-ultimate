               }
            )
         }
      }
      {if_else {== {gamemode get is_practice} TRUE}
         {do
            {set $true_img
               "fusion/ui/textures/load_screens/UI_Loading_BG02_nomip_keep.png"
            }
         }
         {do
            {if_else
               {&&
                  {== {gamemode get is_tour} TRUE}
                  {== {gamemode get is_tour_quickplay} FALSE}
               }
               {do
                  ($veh_img "")
                  ($veh_name {{tour band} vehicle_name})
                  ($rand_tour {random_int 0 3})
                  {switch $veh_name
                     (veh_camper_van
                        {set $veh_img
                           "fusion/ui/textures/load_screens/veh/UI_Loading_Vehicle_CamperVan_nomip_keep.png"
                        }
                     )
                     (veh_minibus
                        {set $veh_img
                           "fusion/ui/textures/load_screens/veh/UI_Loading_Vehicle_minibus_nomip_keep.png"
                        }
                     )
                     (veh_boat
                        {set $veh_img
                           "fusion/ui/textures/load_screens/veh/UI_Loading_Vehicle_Boat_nomip_keep.png"
                        }
                     )
                     (veh_helicopter
                        {set $veh_img
                           "fusion/ui/textures/load_screens/veh/UI_Loading_Vehicle_helicopter_nomip_keep.png"
                        }
                     )
                     (veh_tourbus
                        {set $veh_img
                           "fusion/ui/textures/load_screens/veh/UI_Loading_Vehicle_tourbus_nomip_keep.png"
                        }
                     )
                     (veh_hovercraft
                        {set $veh_img
                           "fusion/ui/textures/load_screens/veh/UI_Loading_Vehicle_hovercraft_nomip_keep.png"
                        }
                     )
                     (veh_submarine
                        {set $veh_img
                           "fusion/ui/textures/load_screens/veh/UI_Loading_Vehicle_Sub_nomip_keep.png"
                        }
                     )
                     (veh_private_jet
                        {set $veh_img
                           "fusion/ui/textures/load_screens/veh/UI_Loading_Vehicle_jet_nomip_keep.png"
                        }
                     )
                     (veh_teleporter
                        {set $veh_img
                           "fusion/ui/textures/load_screens/veh/UI_Loading_Vehicle_teleporter_nomip_keep.png"
                        }
                     )
                  }
                  {switch $rand_tour
                     (0 {set $true_img $free_play_img})
                     (1 {set $true_img $veh_img})
                     (2 {set $true_img $veh_img})
                  }
               }
               {do
                  {set $true_img $free_play_img}
               }
            }
            {set $likeness_img {get_if_likeness}}
            {if {!= $likeness_img ""}
               {set $true_img $likeness_img}
            }
         }
      }
      $true_img
   }
}
{func get_text_token
   {do
      ($token "")
      ($songname {meta_performer song})
      {if_else
         {&&
            {== {gamemode get is_tour} TRUE}
            {== {gamemode get is_tour_quickplay} FALSE}
         }
         {do
            {if_else {> {{tour band} stars} 50}
               {do
                  ($d {random_int 0 4})
                  {switch $d
                     (0 {set $token {localize {random_elem [help_tokens]}}})
                     (1 {set $token {localize {random_elem [important_tokens]}}})
                     (2
                        {set $token
                           {if_else {$this has ($songname)}
                              {localize tip_crash_warning}
                              {localize {random_elem [$songname]}}
                           }
                        }
                     )
                     (3 {set $token {localize {random_elem [lego_tokens]}}})
                  }
               }
               {do
                  {if_else {> {{tour band} stars} 20}
                     {do
                        ($d {random_int 0 2})
                        {switch $d
                           (0 {set $token {localize {random_elem [help_tokens]}}})
                           (1 {set $token {localize {random_elem [important_tokens]}}})
                        }
                     }
                     {do
                        {set $token {localize {random_elem [important_tokens]}}}
                     }
                  }
               }
            }
         }
         {do
            #ifdef KIOSK_DEMO
            {set $token {localize loading_demo}}
            #else
            ($d {random_int 0 2})
            {switch $d
               (0
                  {set $token
                     {if_else {$this has ($songname)}
                        {localize {random_elem [$songname]}}
                        {localize tip_crash_warning}
                     }
                  }
               )
               (1 {set $token {localize {random_elem [lego_tokens]}}})
            }
            #endif
         }
      }
      $token
   }
}
{new Object
   loading_helper
   (screen lrb)
   (get_file
      ($t)
      {unless {== $t songs_loading_panel}
         {set [screen]
            {if_else {!= $loading_screen random} 
               $loading_screen
               {random_elem (gh2 #ifdef HX_NG rb1 #endif rb2 lrb_blue lrb_red)}
            }
         }
      }
      {switch [screen]
         (gh2 "../../../ulti/loading_screens/gh2/loading.milo")
         (rb1 "../../../ulti/loading_screens/rb1/loading.milo")
         (rb2 "../../../ulti/loading_screens/rb2/loading.milo")
         (lrb_blue "load_generic.milo")
         (lrb_red "../meta_loading.milo")
         {if_else {find_elem (post_game_loading_panel generic_red_loading_panel) $t}
            "../meta_loading.milo"
            "load_generic.milo"
         }
      }
   )
   (get_lbl
      ($t)
      {with $t
         {cond
            ({exists Loading_Info.lbl} Loading_Info.lbl)
            ({exists tip.lbl} tip.lbl)
            (TRUE {fail "unable to find loading tip label"})
         }
      }
   )
   (on_enter
      ($t) {do
      ($screen [screen]) {with $t
      {$this set_focus ''}
      {switch $screen
         (gh2
            {foreach $o (flyingtape2.grp loading_word.grp)
               {$o animate
                  (range 0 18144000)
                  (period 604800)
                  (units kTaskUISeconds)
               }
            }
         )
         (rb1 {$this set_focus loading.lbl})
         (rb2
            {do
               ($first_guitar "")
               ($first_bass "")
               ($first_drum "")
               ($first_vocals "")
               {foreach_int $i 0 {user_mgr get_max_users}
                  {do
                     ($user {user_mgr get_user_from_slot $i})
                     ($track
                        {if_else $user
                           {$user get_track_sym}
                           none
                        }
                     )
                     ($object {sprintf "load_icon_%i" $i})
                     ($var {sprintf "first_%s" $track})
                     ($flip FALSE)
                     ($object_to_flip $object)
                     {cond
                        ({== $track guitar}
                           {if_else {== $first_guitar ""}
                              {set $first_guitar $object}
                              {set $flip TRUE}
                           }
                        )
                        ({== $track bass}
                           {if_else {== $first_bass ""}
                              {set $first_bass $object}
                              {do
                                 {set $flip TRUE}
                                 {set $object_to_flip $first_bass}
                              }
                           }
                        )
                        ({== $track drum}
                           {if_else {== $first_drum ""}
                              {set $first_drum $object}
                              {set $flip TRUE}
                           }
                        )
                        ({== $track vocals}
                           {if_else {== $first_vocals ""}
                              {set $first_vocals $object}
                              {do
                                 {set $flip TRUE}
                                 {set $object_to_flip $first_vocals}
                              }
                           }
                        )
                     }
                     {if $flip
                        {do
                           ($sx 1.0)
                           ($sy 1.0)
                           ($sz 1.0)
                           #ifdef HX_NG
                           ($anim {sprintf "%s.anim" $track})
                           #else
                           ($anim {sprintf "%s.mnm" $track})
                           #endif
                           {$object_to_flip get_local_scale $sx $sy $sz}
                           {$object_to_flip set_local_scale {'*' $sx -1.0} $sy $sz}
                           {{$object_to_flip find $anim} animate (delay 0.4) (loop)}
                        }
                     }
                  }
               }
            }
         )
      }
   }})
   (on_load
      ($t) {do
      ($screen [screen]) {with $t
      {switch $screen
         (rb1
            {loading.lbl set_type screen_title}
            {enter.trg set block_transition FALSE}
         )
      }
   }})
}
#define LOAD_CUSTOM (
   (file {loading_helper get_file $this})
   (finish_load {loading_helper on_load $this})
)
{new TexLoadPanel
   post_game_loading_panel
   LOAD_CUSTOM
   (is_really_up FALSE)
   #include tokens.dta
   (load)
   (enter
      {loading_helper on_enter $this}
      {autosave_push [next_screen]}
      {$this set is_really_up TRUE}
      {$this pick_new_hint}
      {$this set is_unloading FALSE}
   )
   (exit_complete
      {if {== [is_unloading] FALSE}
         {$this set is_unloading TRUE}
         {$this set is_really_up FALSE}
         {$this unload}
      }
   )
   (pick_new_hint
      #ifdef KIOSK_DEMO
      {{loading_helper get_lbl $this} set text_token {localize loading_demo}}
      #else
      {if {== [is_really_up] TRUE}
         {do
            ($d {random_int 0 3})
            {switch $d
               (0
                  {{loading_helper get_lbl $this} set
                     text_token
                     {localize {random_elem [help_tokens]}}
                  }
               )
               (1
                  {{loading_helper get_lbl $this} set
                     text_token
                     {localize {random_elem [important_tokens]}}
                  }
               )
               (2
                  {{loading_helper get_lbl $this} set
                     text_token
                     {localize {random_elem [lego_tokens]}}
                  }
               )
            }
            #ifdef HX_XBOX
            {script_task kTaskUISeconds
               (script {$this pick_new_hint})
               (once TRUE)
               (delay 15)
            }
            #endif
         }
      }
      #endif
   )
}
{new UIScreen
   post_game_loading_screen
   (panels post_game_loading_panel)
   (enter {helpbar set_config ((min_height 0))})
}
{new TexLoadPanel
   challenge_loading_panel
   (file "load_chal_ufobreakdown.milo")
   (load
      {do
         ($challenge {tour get_challenge_gig {challenge_mgr get_name}})
         ($img {$challenge get_img})
         {$this add_tex $img "Loading.mat"}
      }
   )
   (enter
      {do
         ($challenge {tour get_challenge_gig {challenge_mgr get_name}})
         {ChalTitle.lbl set text_token {$challenge get_name}}
         {Instructions.lbl set text_token {$challenge get_description}}
      }
   )
}
{new TexLoadPanel
   generic_loading_panel
   LOAD_CUSTOM
   (is_really_up FALSE)
   (img '')
   (hint_text)
   (pre_game FALSE)
   #include tokens.dta
   (load
      {if {!= [img] ''}
         {if {exists "Loading.mat"}
            {$this add_tex [img] "Loading.mat"}
         }
         {$this set img ''}
      }
   )
   (enter
      {loading_helper on_enter $this}
      {$this set is_really_up TRUE}
      {$this pick_new_hint}
   )
   (exit_complete
      {$this set is_really_up FALSE}
      {$this set img ''}
      {if {== [pre_game] TRUE}
         {$this set pre_game FALSE}
      }
   )
   (pick_new_hint
      #ifdef KIOSK_DEMO
      {$this set hint_text loading_demo}
      {{loading_helper get_lbl $this} set text_token {localize [hint_text]}}
      #else
      {do
         ($songname {meta_performer song})
         ($phrase)
         {if {|| {! {gamemode get is_tour}} {gamemode get is_tour_quickplay}}
            {set $phrase {get_song_metadata $songname loading_phrase}}
         }
         {if {== [is_really_up] TRUE}
            {do
               {if_else $phrase
                  {$this set hint_text $phrase}
                  {if_else {&& {== [pre_game] TRUE} {== {song_mgr is_download $songname} 0}}
                     {do
                        {$this set hint_text {get_text_token}}
                     }
                     {do
                        {if_else {&& {exists tour} {tour band}}
                           {if_else {== {{tour band} shown_first_load_hint} FALSE}
                              {$this set hint_text loading_important_help09}
                              {$this set hint_text {random_elem [lego_tokens]}}
                           }
                           {if_else {== {get_if_likeness} ""}
                              {$this set hint_text {random_elem [lego_tokens]}}
                              {$this set hint_text matchmaking_char_override}
                           }
                        }
                     }
                  }
               }
               {{loading_helper get_lbl $this} set text_token {localize [hint_text]}}
               #ifdef HX_XBOX
               {script_task kTaskUISeconds
                  (script {$this pick_new_hint})
                  (once TRUE)
                  (delay 15)
               }
               #endif
            }
         }
      }
      #endif
   )
   (block_event
      ($event)
      {!= $event content_file_read_failed}
   )
}
{new TexLoadPanel
   generic_red_loading_panel
   LOAD_CUSTOM
   (is_really_up FALSE)
   #include tokens.dta
   (load)
   (enter
      {loading_helper on_enter $this}
      {$this set is_really_up TRUE}
      {$this pick_new_hint}
